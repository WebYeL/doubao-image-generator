# Doubao 图片生成器 - 生产环境配置
# 复制到 backend/.env 并填入真实值

# API 密钥（必填）- 从火山引擎控制台获取
ARK_API_KEY=你的火山引擎API密钥

# API 配置
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_NAME=doubao-seedream-5-0-260128

# 服务器配置
HOST=127.0.0.1
PORT=8886
DEBUG=false

# 图片存储
IMAGE_STORAGE_PATH=./generated_images

# CORS 配置（允许的域名，逗号分隔）
CORS_ORIGINS=["http://yrl0113.top","https://yrl0113.top","http://107.173.204.17"]
